{
	"name": "api",
	"version": "0.1.0",
	"packageManager": "pnpm@10.20.0",
	"private": true,
	"scripts": {
		"build": "swc src -d dist --ignore '**/*.d.ts' --strip-leading-paths -D",
		"start": "tsx src/main --env-file=.env",
		"start:dev": "tsx watch src/main --env-file=.env",
		"start:prod": "node dist/main --env-file=.env",
		"check": "biome check --write --unsafe",
		"generate": "prisma generate"
	},
	"dependencies": {
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.1.0",
		"@fastify/swagger": "^9.5.2",
		"@prisma/client": "^6.18.0",
		"@scalar/fastify-api-reference": "^1.38.1",
		"bcryptjs": "^3.0.2",
		"cron": "^4.3.3",
		"fastify": "^5.6.1",
		"fastify-plugin": "^5.1.0",
		"fastify-type-provider-zod": "^6.1.0",
		"handlebars": "^4.7.8",
		"ioredis": "^5.8.2",
		"jose": "^6.1.0",
		"mjml": "^4.16.1",
		"pdfkit": "^0.17.2",
		"prisma": "^6.18.0",
		"resend": "^6.4.0",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.2",
		"@faker-js/faker": "^10.1.0",
		"@swc/cli": "^0.8.0",
		"@swc/core": "^1.15.18",
		"@types/mjml": "^4.7.4",
		"@types/node": "^25.3.5",
		"@types/pdfkit": "^0.17.3",
		"pino-pretty": "^13.1.2",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	},
	"prisma": {
		"seed": "tsx prisma/seed"
	}
}
